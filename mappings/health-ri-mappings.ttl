    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "The source denotes a person, while Male is modeled as an outcome category. Male is the relevant comparison target because it is the exact lexical match, but exact equivalence was rejected because the person-level source and outcome-level target are not exactly the same in meaning. Created with support from the Mapping Assistant."@en,
        "The source value Male intentionally combines male-as-sex and male-as-gender. Male is the relevant target because it represents a consolidated male classification, but exact equivalence was rejected because the source also keeps unresolved framing between a coded value and a person reading. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasExactMeaning ;
    owl:annotatedSource ncit:C20197 ;
    owl:annotatedTarget hrio:Male ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "category" ;
    sssom:object_label "Male"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:predicate_modifier "Not" ;
    sssom:record_id "hrim:1209BC2A"^^xsd:anyURI ;
    sssom:subject_label "Male"@en ;
    sssom:subject_source <http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus_26.02d.owl>,
        <https://evs.nci.nih.gov/ftp1/CDISC/SDTM/Archive/SDTM%20Terminology%202025-09-26.pdf> ;
    sssom:subject_source_version "CDISC SDTM Controlled Terminology, 2025-09-26 — SEX (Sex)",
        "NCI Thesaurus 26.02d" .

