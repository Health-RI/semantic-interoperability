hrim:002C0C53 a sssom:Mapping ;
    dcterms:creator <https://w3id.org/health-ri/semantic-interoperability> ;
    dcterms:identifier "hrim:002C0C53"^^xsd:anyURI ;
    dcterms:issued "2026-03-23"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "The source is a male-related finding but does not state a chromosomal or karyotypic basis. Karyotypic Male Sex is the relevant comparison target, but exact equivalence was rejected because the added basis is not present in the source. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasExactMeaning ;
    owl:annotatedSource snomed:248153007 ;
    owl:annotatedTarget hrio:KaryotypicMaleSex ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "subkind" ;
    sssom:object_label "Karyotypic Male Sex"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:predicate_modifier "Not" ;
    sssom:record_id "hrim:002C0C53"^^xsd:anyURI ;
    sssom:reviewer_id orcid:0009-0002-3089-9558 ;
    sssom:reviewer_label "Ana Konrad" ;
    sssom:subject_label "Male (finding)"@en ;
    sssom:subject_source <http://snomed.info/sct/900000000000207008/version/20260301> ;
    sssom:subject_source_version "SNOMED CT International Edition, March 2026 release" .

hrim:0086F75C a sssom:Mapping ;
    dcterms:creator <https://w3id.org/health-ri/semantic-interoperability> ;
    dcterms:identifier "hrim:0086F75C"^^xsd:anyURI ;
    dcterms:issued "2026-03-23"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "The source is a finding or observation about the sex of a baby. Sex at Birth is the relevant comparison target because it is closely related, but exact equivalence was rejected because the source is a finding and the target is a sex classification. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasExactMeaning ;
    owl:annotatedSource snomed:302081005 ;
    owl:annotatedTarget hrio:SexAtBirth ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "subkind" ;
    sssom:object_label "Sex at Birth"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:predicate_modifier "Not" ;
    sssom:record_id "hrim:0086F75C"^^xsd:anyURI ;
    sssom:subject_label "Finding of sex of baby (finding)"@en ;
    sssom:subject_source <http://snomed.info/sct/900000000000207008/version/20260301> ;
    sssom:subject_source_version "SNOMED CT International Edition, March 2026 release" .

hrim:00BCD535 a sssom:Mapping ;
    dcterms:creator <https://w3id.org/health-ri/semantic-interoperability> ;
    dcterms:identifier "hrim:00BCD535"^^xsd:anyURI ;
    dcterms:issued "2026-03-23"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "OTHER_KARYOTYPE denotes a residual karyotypic-sex value for cases that are none of the listed types. Karyotypical Indeterminate Person is a relevant comparison target because it concerns chromosomal cases outside the usual categories, but exact equivalence was rejected because the target applies to a person and is more specific than the source. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasExactMeaning ;
    owl:annotatedSource hri-ga4gh-phenopacket-schema:other_karyotype ;
    owl:annotatedTarget hrio:KaryotypicalIndeterminatePerson ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "subkind" ;
    sssom:object_label "Karyotypical Indeterminate Person"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:predicate_modifier "Not" ;
    sssom:record_id "hrim:00BCD535"^^xsd:anyURI ;
    sssom:subject_label "OTHER_KARYOTYPE"@en ;
    sssom:subject_source <https://phenopacket-schema.readthedocs.io/en/2.0.0/karyotypicsex.html> ;
    sssom:subject_source_version "GA4GH Phenopacket Schema 2.0.0 — KaryotypicSex enumeration" .

hrim:011373B0 a sssom:Mapping ;
    dcterms:creator <https://w3id.org/health-ri/semantic-interoperability> ;
    dcterms:identifier "hrim:011373B0"^^xsd:anyURI ;
    dcterms:issued "2026-03-23"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "This source denotes a nonbinary gender identity. Non-binary Gender is the relevant broader target because it preserves the explicit non-binary gender meaning while covering a wider umbrella class. Exact equivalence was not used because the source is narrower than this target. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasNarrowerMeaningThan ;
    owl:annotatedSource obo:GSSO_002328 ;
    owl:annotatedTarget hrio:NonBinaryGender ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "phaseMixin" ;
    sssom:object_label "Non-binary Gender"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:record_id "hrim:011373B0"^^xsd:anyURI ;
    sssom:reviewer_id orcid:0000-0001-8397-2339 ;
    sssom:reviewer_label "Douwe Spaanderman" ;
    sssom:subject_label "nonbinary gender identity"@en ;
    sssom:subject_source <http://purl.obolibrary.org/obo/gsso/releases/2.0.5/gsso.owl> ;
    sssom:subject_source_version "2.0.35" .

hrim:019A9367 a sssom:Mapping ;
    dcterms:creator <https://w3id.org/health-ri/semantic-interoperability> ;
    dcterms:identifier "hrim:019A9367"^^xsd:anyURI ;
    dcterms:issued "2026-03-23"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    pav:authoredBy orcid:0000-0003-2736-7817 ;
    pav:authoredOn "2026-03-13"^^xsd:date ;
    rdfs:comment "The source concept cisgender centers on alignment between gender identity and sex assigned at birth, which makes Cisgender Person a relevant comparison target. Exact equivalence was rejected because the HRIO class applies to a person with added person-bounded structure, while the source is not safely limited to persons. Created with support from the Mapping Assistant."@en ;
    owl:annotatedProperty hriv:hasExactMeaning ;
    owl:annotatedSource obo:GSSO_004240 ;
    owl:annotatedTarget hrio:CisgenderPerson ;
    sssom:author_label "Pedro Paulo Favato Barcelos" ;
    sssom:creator_label "Health-RI Semantic Interoperability Initiative" ;
    sssom:mapping_justification semapv:ManualMappingCuration ;
    sssom:object_category "phase" ;
    sssom:object_label "Cisgender Person"@en ;
    sssom:object_source hrio: ;
    sssom:object_source_version "2.1.0" ;
    sssom:predicate_modifier "Not" ;
    sssom:record_id "hrim:019A9367"^^xsd:anyURI ;
    sssom:reviewer_id orcid:0009-0002-3089-9558 ;
    sssom:reviewer_label "Ana Konrad" ;
    sssom:subject_label "cisgender"@en ;
    sssom:subject_source <http://purl.obolibrary.org/obo/gsso/releases/2.0.5/gsso.owl> ;
    sssom:subject_source_version "2.0.38" .

